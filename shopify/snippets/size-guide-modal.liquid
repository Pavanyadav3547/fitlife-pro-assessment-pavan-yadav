<!-- size-guide-modal.liquid -->
<div id="fitwear-size-modal" class="fitwear-modal" aria-hidden="true" role="dialog">
  <div class="fitwear-modal-overlay" data-close-modal></div>
  <div class="fitwear-modal-container">
    <button type="button" class="fitwear-modal-close" data-close-modal aria-label="Close modal">&times;</button>
    <div class="fitwear-modal-header">
      <h3>FitWear Size Guide</h3>
    </div>
    <div class="fitwear-modal-body">
      <div class="fitwear-size-tabs">
        <table class="fitwear-size-table">
          <thead>
            <tr>
              <th>Size</th>
              <th>Chest (in)</th>
              <th>Waist (in)</th>
              <th>Hips (in)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>S</td>
              <td>34 - 36</td>
              <td>28 - 30</td>
              <td>34 - 36</td>
            </tr>
            <tr>
              <td>M</td>
              <td>38 - 40</td>
              <td>32 - 34</td>
              <td>38 - 40</td>
            </tr>
            <tr>
              <td>L</td>
              <td>42 - 44</td>
              <td>36 - 38</td>
              <td>42 - 44</td>
            </tr>
            <tr>
              <td>XL</td>
              <td>46 - 48</td>
              <td>40 - 42</td>
              <td>46 - 48</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="fitwear-size-note">
        <p>Measurements refer to body size, not garment dimensions. If you are between sizes, we recommend ordering the larger size for a looser fit.</p>
        <div class="modal-metafield-link-box" style="margin-top: 15px;">
          <a href="#" id="modal-size-guide-external" target="_blank" class="fitwear-hero-cta" style="font-size: 0.85rem; padding: 8px 16px;">View Full Size Chart Link</a>
        </div>
      </div>
    </div>
  </div>
</div>
